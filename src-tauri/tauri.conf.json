{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "beni-iceri-al-DPI",
  "version": "1.0.1",
  "identifier": "com.o7xmarasli.beni-iceri-al-dpi",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "beni-iceri-al-DPI",
        "width": 420,
        "height": 820,
        "resizable": false,
        "fullscreen": false,
        "center": true,
        "decorations": false,
        "devtools": false,
        "dragDropEnabled": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src ipc: http://ipc.localhost; object-src 'none'; frame-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'none'; worker-src 'none'",
      "freezePrototype": true
    }
  },
  "bundle": {
    "active": true,
    "externalBin": [
      "binaries/beni-iceri-al-DPI-proxy"
    ],
    "resources": [
      "binaries/npcap-installer.exe"
    ],
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "hooks.nsi"
      }
    }
  }
}
